generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String?
  author      String?
  description String?
  content     String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Students {
  id        String   @id @default(uuid())
  email     String   @unique
  firstName String
  lastName  String
  username  String
  password  String
  domains   String[]
  role1     String
  month     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects StudentProject[]
}

model Project {
  id      String @id @default(uuid())
  title   String
  slug    String @unique
  domain  String
  summary String @db.Text
  content String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentEnrollments StudentProject[]
}

model StudentProject {
  id String @id @default(uuid())

  studentId String
  student   Students @relation(fields: [studentId], references: [id])

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  status         ProjectStatus @default(SELECTED)
  submissionLink String?
  feedback       String?

  assignedAt  DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  @@unique([studentId, projectId])
}

enum ProjectStatus {
  SELECTED
  IN_PROGRESS
  SUBMITTED
  COMPLETED
}
